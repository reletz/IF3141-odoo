            <field name="street">Cibeusi, Jatinangor</field>
            <field name="notes">Pelanggan tidak ingin direminder (opt-out)</field>
        </record>

        <!-- 4. Histori Servis Pelanggan (Tanggal Simulasi) -->
        
        <!-- Budi: Servis 15 hari lalu -> Belum saatnya direminder (Baru setengah interval) -->
        <record id="histori_budi_demo_v2" model="bts.service.history">
            <field name="partner_id" ref="customer_budi_demo_v2"/>
            <field name="service_type">ringan</field>
            <field name="service_date" eval="(datetime.datetime.today() - datetime.timedelta(days=15)).strftime('%Y-%m-%d')"/>
            <field name="vehicle_mileage">12000</field>
            <field name="complaint">Tarikan agak berat</field>
            <field name="action_taken">Ganti oli mesin, bersihkan CVT</field>
            <field name="total_cost">150000</field>
        </record>

        <!-- Siti: Servis 28 hari lalu -> Masuk Offset H-2 Reminder Servis Bulanan -->
        <record id="histori_siti_demo_v2" model="bts.service.history">
            <field name="partner_id" ref="customer_siti_demo_v2"/>
            <field name="service_type">ringan</field>
            <field name="service_date" eval="(datetime.datetime.today() - datetime.timedelta(days=28)).strftime('%Y-%m-%d')"/>
            <field name="vehicle_mileage">8500</field>
            <field name="complaint">Servis rutin</field>
            <field name="action_taken">Ganti oli mesin dan gardan</field>
            <field name="total_cost">90000</field>
        </record>

        <!-- Ahmad: Servis 35 hari lalu -> Jatuh tempo sebulan kelewat 5 hari (Overdue tapi msh masuk batas toleransi 7 hari) -->
        <record id="histori_ahmad_demo_v2_ringan" model="bts.service.history">
            <field name="partner_id" ref="customer_ahmad_demo_v2"/>
            <field name="service_type">ringan</field>
            <field name="service_date" eval="(datetime.datetime.today() - datetime.timedelta(days=35)).strftime('%Y-%m-%d')"/>
            <field name="vehicle_mileage">21000</field>
            <field name="complaint">Rem depan bunyi</field>
            <field name="action_taken">Servis ringan, ganti kampas rem depan</field>
            <field name="total_cost">220000</field>
        </record>
        
        <!-- Ahmad (Riwayat Lampau): Servis Besar Terakhir 175 hari lalu (Masuk offset H-5 Servis 180 hari) -->
        <record id="histori_ahmad_demo_v2_berat" model="bts.service.history">
            <field name="partner_id" ref="customer_ahmad_demo_v2"/>
            <field name="service_type">berat</field>
            <field name="service_date" eval="(datetime.datetime.today() - datetime.timedelta(days=175)).strftime('%Y-%m-%d')"/>
            <field name="vehicle_mileage">15000</field>
            <field name="complaint">Tarikan tersendat dan mati mendadak</field>
            <field name="action_taken">Servis besar, bersihkan injektor, ganti V-Belt</field>
            <field name="total_cost">550000</field>
        </record>

        <!-- Rina: Servis Berat 185 hari lalu -> Overdue toleransi -->
        <record id="histori_rina_demo_v2_berat" model="bts.service.history">
            <field name="partner_id" ref="customer_rina_demo_v2"/>
            <field name="service_type">berat</field>
            <field name="service_date" eval="(datetime.datetime.today() - datetime.timedelta(days=185)).strftime('%Y-%m-%d')"/>
            <field name="vehicle_mileage">32000</field>
            <field name="complaint">Getar saat tarikan awal</field>
            <field name="action_taken">Overhaul CVT, Ganti Roller</field>
            <field name="total_cost">350000</field>
        </record>

        <!-- Dodi: Opt Out Customer (Servis 29 hari lalu) -->
        <record id="histori_dodi_demo_v2" model="bts.service.history">
            <field name="partner_id" ref="customer_dodi_demo_v2"/>
            <field name="service_type">ringan</field>
            <field name="service_date" eval="(datetime.datetime.today() - datetime.timedelta(days=29)).strftime('%Y-%m-%d')"/>
            <field name="vehicle_mileage">45000</field>
            <field name="complaint">Ganti oli</field>
            <field name="action_taken">Ganti oli mesin</field>
            <field name="total_cost">65000</field>
        </record>

    </data>
</odoo>