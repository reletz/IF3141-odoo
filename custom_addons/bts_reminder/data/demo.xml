<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- 1. Parameter Reminder Interval -->
        <record id="reminder_param_ringan_demo_v2" model="bts.reminder.parameter">
            <field name="service_type">ringan</field>
            <field name="interval_days">30</field>
            <field name="offset_days">3</field>
            <field name="tolerance_days">7</field>
            <field name="description">Parameter standar untuk servis ringan bulanan (Ganti oli berkala).</field>
        </record>

        <record id="reminder_param_berat_demo_v2" model="bts.reminder.parameter">
            <field name="service_type">berat</field>
            <field name="interval_days">180</field>
            <field name="offset_days">7</field>
            <field name="tolerance_days">14</field>
            <field name="description">Parameter standar untuk servis besar / overhaul per 6 bulan.</field>
        </record>

        <!-- 2. Template Pesan WhatsApp -->
        <record id="message_template_ringan" model="bts.message.template">
            <field name="name">Template Servis Ringan</field>
            <field name="service_type">ringan</field>
            <field name="body">Halo {nama},
Ini pesan pengingat dari AHASS BTS MOTOR Jatinangor!

Motor {tipe_kendaraan} kamu ({nomor_polisi}) bentar lagi waktunya servis ringan berkala lho. Terakhir kali diservis tanggal {tanggal_servis_terakhir}. 

Yuk rawat mesin motormu agar selalu prima. Ditunggu kedatangannya ya!</field>
        </record>
        
        <record id="message_template_berat" model="bts.message.template">
            <field name="name">Template Servis Besar</field>
            <field name="service_type">berat</field>
            <field name="body">Halo Pak/Bu {nama}, salam dari AHASS BTS MOTOR Jatinangor.

Kami melihat catatan sistem bahwa {tipe_kendaraan} dengan nomor {nomor_polisi} milik Anda sudah mendekati jadwal Servis Besar (overhaul/cek CVT).
Servis terakhir tercatat pada {tanggal_servis_terakhir}. Pastikan performa kendaraan Anda tetap awet. Silakan mampir ke bengkel kami!</field>
        </record>

        <record id="message_template_overdue" model="bts.message.template">
            <field name="name">Template Terlambat Servis</field>
            <field name="service_type">all</field>
            <field name="body">Halo {nama}, jangan lupa ganti oli dan cek motormu!

Kami dari AHASS BTS Jatinangor mengingatkan bahwa {tipe_kendaraan} Anda ({nomor_polisi}) sudah melewati jadwal servis rutin (terakhir servis: {tanggal_servis_terakhir}).
Jangan tunggu sampai rusak, yuk segera kunjungi bengkel kami sebelum kendalanya merembet.</field>
        </record>

        <!-- 3. Master Data Pelanggan -->
        <record id="customer_budi_demo_v2" model="res.partner">
            <field name="name">Budi Santoso</field>
            <field name="whatsapp_number">081234567890</field>
            <field name="vehicle_type">Honda Beat</field>
            <field name="license_plate">D 1234 XY</field>
            <field name="vehicle_year">2020</field>
            <field name="contact_preference">pagi</field>
            <field name="is_active_customer">True</field>
            <field name="ring_1">True</field>
            <field name="street">Jl. Raya Jatinangor No. 123, Sumedang</field>
        </record>

        <record id="customer_siti_demo_v2" model="res.partner">
            <field name="name">Siti Nurhaliza</field>
            <field name="whatsapp_number">085678901234</field>
            <field name="vehicle_type">Honda Vario 160</field>
            <field name="license_plate">D 5678 AB</field>
            <field name="vehicle_year">2021</field>
            <field name="contact_preference">siang</field>
            <field name="is_active_customer">True</field>
            <field name="ring_1">False</field>
            <field name="street">Perumahan Jatinangor Indah Blok A/5</field>
        </record>

        <record id="customer_ahmad_demo_v2" model="res.partner">
            <field name="name">Ahmad Wijaya</field>
            <field name="whatsapp_number">087890123456</field>
            <field name="vehicle_type">Honda PCX 160</field>
            <field name="license_plate">D 9012 CD</field>
            <field name="vehicle_year">2022</field>
            <field name="contact_preference">sore</field>
            <field name="is_active_customer">True</field>
            <field name="ring_1">True</field>
            <field name="street">Jl. Kolonel Ahmad Syam, Cikeruh</field>
        </record>

        <record id="customer_rina_demo_v2" model="res.partner">
            <field name="name">Rina Melati</field>
            <field name="whatsapp_number">089812345678</field>
            <field name="vehicle_type">Honda Scoopy</field>
            <field name="license_plate">Z 3456 EF</field>
            <field name="vehicle_year">2023</field>
            <field name="contact_preference">siang</field>
            <field name="is_active_customer">True</field>
            <field name="ring_1">False</field>
            <field name="street">Sayang, Jatinangor</field>
        </record>

        <record id="customer_dodi_demo_v2" model="res.partner">
            <field name="name">Dodic Kurniawan</field>
            <field name="whatsapp_number">081345678901</field>
            <field name="vehicle_type">Honda Supra X</field>
            <field name="license_plate">D 7890 GH</field>
            <field name="vehicle_year">2018</field>
            <field name="contact_preference">pagi</field>
            <field name="is_active_customer">False</field>
